# --- football-data.org ---
# Free API token from https://www.football-data.org/client/register
FOOTBALL_DATA_TOKEN=your-football-data-token

# --- Anthropic (match summaries) ---
ANTHROPIC_API_KEY=your-anthropic-key
# Model used to write the brief match recap. Defaults to claude-opus-4-8.
SUMMARY_MODEL=claude-opus-4-8

# --- Email (Gmail SMTP) ---
# Use a Gmail App Password (https://myaccount.google.com/apppasswords), NOT your
# normal account password. Requires 2-Step Verification enabled on the account.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youraddress@gmail.com
SMTP_PASSWORD=your-16-char-app-password
EMAIL_FROM=youraddress@gmail.com
# Where the digest is sent:
EMAIL_TO=joran.k@gmail.com

# --- Behaviour ---
# IANA timezone used for the "today" window and the morning digest hour.
TIMEZONE=Europe/Amsterdam
# Hour of day (0-23, local TIMEZONE) at/after which the morning digest is sent.
MORNING_DIGEST_HOUR=8
# Minutes before kickoff to send the pre-match nudge.
PREMATCH_LEAD_MINUTES=60
# football-data.org competition code for the World Cup.
COMPETITION_CODE=WC

# Paths (optional; sensible defaults shown)
STATE_DB=state.db
TEAMS_FILE=teams.json
DASHBOARD_FILE=dashboard.html
