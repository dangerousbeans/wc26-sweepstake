<!doctype html>
<html>
  <body style="font-family: Arial, Helvetica, sans-serif; color: #1a1a1a;">
    <h2>🏁 Full time: {{ match.home_name }} {{ match.home_score }}–{{ match.away_score }} {{ match.away_name }}</h2>
    <p>{{ match | owners_label }}
       {% if match.stage %}<br>{{ match.stage }}{% endif %}
       {% if match.group %}· {{ match.group }}{% endif %}</p>
    <p style="font-size:15px; line-height:1.5;">{{ summary }}</p>
    {% if match.scorers %}
    <p style="color:#444; font-size:13px;">
      Goals:
      {% for s in match.scorers %}{{ s.name }}{% if s.minute is not none %} {{ s.minute }}'{% endif %}{% if not loop.last %}, {% endif %}{% endfor %}
    </p>
    {% endif %}
    <p style="color:#888; font-size:12px;">FootballWatcherBot</p>
  </body>
</html>
