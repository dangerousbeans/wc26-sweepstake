<!doctype html>
<html>
  <body style="font-family: Arial, Helvetica, sans-serif; color: #1a1a1a;">
    <h2>⏰ Kicking off soon: {{ match.home_name }} vs {{ match.away_name }}</h2>
    <p><strong>{{ match.utc_kickoff | local_time }}</strong>
       {% if match.stage %}· {{ match.stage }}{% endif %}
       {% if match.group %}· {{ match.group }}{% endif %}</p>
    <p>{{ match | owners_label }}</p>
    <p style="color:#888; font-size:12px;">FootballWatcherBot</p>
  </body>
</html>
