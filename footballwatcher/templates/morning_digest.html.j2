<!doctype html>
<html>
  <body style="font-family: Arial, Helvetica, sans-serif; color: #1a1a1a;">
    <h2>⚽ World Cup — today's sweepstake matches</h2>
    <p>{{ digest_date }} — {{ matches|length }} match{{ '' if matches|length == 1 else 'es' }} involving our teams.</p>
    <table cellpadding="6" cellspacing="0" border="0" style="border-collapse: collapse;">
      <thead>
        <tr style="background:#f0f0f0; text-align:left;">
          <th>Kickoff</th><th>Match</th><th>Owners</th>
        </tr>
      </thead>
      <tbody>
        {% for m in matches %}
        <tr style="border-bottom:1px solid #eee;">
          <td>{{ m.utc_kickoff | local_time }}</td>
          <td>{{ m.home_name }} vs {{ m.away_name }}</td>
          <td>{{ m | owners_label }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
    <p style="color:#888; font-size:12px;">FootballWatcherBot</p>
  </body>
</html>
